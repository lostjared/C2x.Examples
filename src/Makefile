dl: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 dl
.PHONY : dl

# fast build rule for target.
dl/fast:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/dl.dir/build.make CMakeFiles/dl.dir/build
.PHONY : dl/fast

